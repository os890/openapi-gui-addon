<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <!--
      Cookie / session approach: protect the ENTIRE WAR so the first
      request triggers the full OIDC flow (redirect to Keycloak, login,
      JSESSIONID established). Every subsequent same-origin request —
      including Swagger UI's "Try it out" — automatically carries the
      session cookie and is accepted by Elytron OIDC without any Bearer
      token. No popup, no window.opener, no COOP interaction.
    -->
    <security-constraint>
        <web-resource-collection>
            <web-resource-name>Whole WAR</web-resource-name>
            <url-pattern>/*</url-pattern>
        </web-resource-collection>
        <auth-constraint>
            <role-name>*</role-name>
        </auth-constraint>
    </security-constraint>

    <login-config>
        <auth-method>OIDC</auth-method>
        <realm-name>demo</realm-name>
    </login-config>

    <!--
      Turn on Resteasy's method-level role-based security so @RolesAllowed /
      @PermitAll / @DenyAll are enforced on JAX-RS resources. Without this
      flag, web.xml's auth-constraint lets any authenticated user through
      and annotations on resource methods are silently ignored — meaning a
      user with only the "user" role could still call a @RolesAllowed("admin")
      method.
    -->
    <context-param>
        <param-name>resteasy.role.based.security</param-name>
        <param-value>true</param-value>
    </context-param>

    <security-role>
        <role-name>user</role-name>
    </security-role>
    <security-role>
        <role-name>admin</role-name>
    </security-role>

</web-app>
